; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ILL WILL"
run/main_scene="res://estate/estate.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://assets/ui/icon.png"
config/windows_native_icon="res://assets/ui/illwill.ico"

[autoload]

Migrate="*res://core/migrate.gd"
Dialog="*res://core/dialog.gd"
GameState="*res://scripts/game_state.gd"
Sfx="*res://scripts/sfx.gd"
Ambience="*res://core/ambience.gd"
PlayerInput="*res://core/player_input.gd"
EstateState="*res://estate/estate_state.gd"
PartySetup="*res://core/party_setup.gd"
Music="*res://core/music.gd"
Cosmetics="*res://core/cosmetics.gd"
MomentScribe="*res://core/moment_scribe.gd"
Transition="*res://core/transition.gd"
VerifyCapture="*res://scripts/verify_capture.gd"
NetSession="*res://core/net_session.gd"
ProcessionBoot="*res://estate/procession/procession_boot.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[gui]

theme/custom="res://assets/ui/theme.tres"
theme/custom_font="res://assets/fonts/Fredoka.ttf"

[input]

; GAMEPAD EVERYWHERE (L1): Godot 4.6's built-in ui_accept/ui_cancel ship with
; KEYBOARD events ONLY — the gamepad face buttons are absent, so a pad could move
; menu focus (ui_up/down/left/right DO carry D-pad + left stick by default) but
; never CONFIRM or BACK. We redeclare both actions with their keyboard defaults
; PLUS JOY_BUTTON_A (0) = accept and JOY_BUTTON_B (1) = cancel, reviving every
; mouse-first menu (title, party setup, auction, wardrobe, pause) for pad play.
ui_accept={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194309,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194310,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":32,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventJoypadButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"button_index":0,"pressure":0.0,"pressed":false,"script":null)
]
}
ui_cancel={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194305,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventJoypadButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"button_index":1,"pressure":0.0,"pressed":false,"script":null)
]
}
restart={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":82,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

anti_aliasing/quality/msaa_3d=2
