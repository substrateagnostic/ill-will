[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/menu.gd" id="1_menu"]
[ext_resource type="FontFile" path="res://assets/fonts/LuckiestGuy-Regular.ttf" id="2_luckiest"]
[ext_resource type="FontFile" path="res://assets/fonts/Baloo2.ttf" id="3_baloo"]

[sub_resource type="StyleBoxFlat" id="bg_style"]
bg_color = Color(0.16, 0.34, 0.22, 1)

[node name="Menu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_menu")

[node name="BG" type="Panel" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_styles/panel = SubResource("bg_style")

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Box" type="VBoxContainer" parent="Center"]
layout_mode = 2
theme_override_constants/separation = 26

[node name="Title" type="Label" parent="Center/Box"]
layout_mode = 2
theme_override_fonts/font = ExtResource("2_luckiest")
theme_override_font_sizes/font_size = 92
theme_override_colors/font_color = Color(1, 0.85, 0.2, 1)
theme_override_colors/font_outline_color = Color(0.15, 0.08, 0.02, 1)
theme_override_constants/outline_size = 18
text = "PAR FOR THE CURSE"
horizontal_alignment = 1

[node name="Subtitle" type="Label" parent="Center/Box"]
layout_mode = 2
theme_override_fonts/font = ExtResource("3_baloo")
theme_override_font_sizes/font_size = 28
theme_override_colors/font_color = Color(0.92, 0.95, 0.9, 1)
text = "Build the traps. Survive the traps. Blame your friends."
horizontal_alignment = 1

[node name="Spacer" type="Control" parent="Center/Box"]
layout_mode = 2
custom_minimum_size = Vector2(0, 20)

[node name="PlayersLabel" type="Label" parent="Center/Box"]
layout_mode = 2
theme_override_fonts/font = ExtResource("3_baloo")
theme_override_font_sizes/font_size = 24
theme_override_colors/font_color = Color(0.8, 0.9, 0.8, 1)
text = "PLAYERS ON THIS COUCH"
horizontal_alignment = 1

[node name="Players" type="HBoxContainer" parent="Center/Box"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 18

[node name="P2" type="Button" parent="Center/Box/Players"]
layout_mode = 2
custom_minimum_size = Vector2(110, 64)
toggle_mode = true
theme_override_font_sizes/font_size = 32
text = "2"

[node name="P3" type="Button" parent="Center/Box/Players"]
layout_mode = 2
custom_minimum_size = Vector2(110, 64)
toggle_mode = true
theme_override_font_sizes/font_size = 32
text = "3"

[node name="P4" type="Button" parent="Center/Box/Players"]
layout_mode = 2
custom_minimum_size = Vector2(110, 64)
toggle_mode = true
theme_override_font_sizes/font_size = 32
text = "4"

[node name="Spacer2" type="Control" parent="Center/Box"]
layout_mode = 2
custom_minimum_size = Vector2(0, 10)

[node name="StartBtn" type="Button" parent="Center/Box"]
layout_mode = 2
custom_minimum_size = Vector2(340, 84)
theme_override_fonts/font = ExtResource("2_luckiest")
theme_override_font_sizes/font_size = 40
text = "TEE OFF"

[node name="EstateBtn" type="Button" parent="Center/Box"]
layout_mode = 2
custom_minimum_size = Vector2(340, 60)
theme_override_fonts/font = ExtResource("3_baloo")
theme_override_font_sizes/font_size = 26
text = "ESTATE NIGHT  (beta)"

[node name="Footer" type="Label" parent="."]
layout_mode = 1
anchor_top = 1.0
anchor_bottom = 1.0
anchor_right = 1.0
offset_top = -50.0
offset_bottom = -18.0
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(0.7, 0.8, 0.7, 1)
text = "One mouse. Nine rounds. The course remembers everything."
horizontal_alignment = 1
